# =============================================================================
# VirtualizeMCPDemo — Environment Variables
# =============================================================================
# Copy this file to .env for local testing, or add each variable as a
# GitHub Actions secret (Settings → Secrets and variables → Actions).
#
# NEVER commit a populated .env file to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic — Claude LLM (https://console.anthropic.com)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Atlassian Jira Cloud — used by the Jira MCP Server
# How to get an API token: https://id.atlassian.com/manage-profile/security/api-tokens
# -----------------------------------------------------------------------------
ATLASSIAN_SITE_NAME=your-company        # e.g. "acme" for acme.atlassian.net
ATLASSIAN_USER_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=ATATT3x...

# -----------------------------------------------------------------------------
# Parasoft Virtualize MCP Server — locally deployed on the self-hosted runner
#
# PARASOFT_VIRTUALIZE_MCP_URL  : HTTP/SSE endpoint where the Virtualize MCP
#                                Server is listening (e.g. http://localhost:4000/sse)
# PARASOFT_VIRTUALIZE_URL      : Base URL of the Virtualize server REST API
#                                (default http://localhost:9080)
# PARASOFT_VIRTUALIZE_USER     : Virtualize server username
# PARASOFT_VIRTUALIZE_PASSWORD : Virtualize server password
# -----------------------------------------------------------------------------
PARASOFT_VIRTUALIZE_MCP_URL=http://localhost:4000/sse
PARASOFT_VIRTUALIZE_URL=http://localhost:9080
PARASOFT_VIRTUALIZE_USER=admin
PARASOFT_VIRTUALIZE_PASSWORD=changeme
